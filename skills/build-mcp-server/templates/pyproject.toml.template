# uv 기반 프로젝트 메타데이터. render_server.py 가 {{serverName}} 을 채운다.
# Python 은 3.12 로 핀 — 최신 3.14 는 일부 의존성 휠이 아직 없을 수 있음.
[project]
name = "{{serverName}}"
version = "0.1.0"
description = "MCP server generated by /build-mcp-server"
requires-python = ">=3.12"
dependencies = [
    "mcp[cli]",   # SDK 내장 FastMCP 포함. 안정 v1.x 로 해석됨.
]

[tool.uv]
# 필요 시 여기에 추가 의존성. 예: "httpx", "pandas" 등.
